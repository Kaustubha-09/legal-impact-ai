# Postgres with the pgvector extension enabled.
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/legal_impact_ai

# Free signup at https://api.congress.gov/sign-up
CONGRESS_API_KEY=

# Free signup at https://legiscan.com/legiscan
LEGISCAN_API_KEY=

# Free signup at https://resend.com — used for the weekly email digest.
RESEND_API_KEY=

# Free "Read" token at https://huggingface.co/settings/tokens — used to
# compute embeddings via the Inference API instead of loading
# sentence-transformers/PyTorch in-process (too heavy for a 512MB instance).
HUGGINGFACE_API_KEY=

# Comma-separated list of allowed frontend origins for CORS.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
